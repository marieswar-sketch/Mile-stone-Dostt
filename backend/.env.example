# ── Server ────────────────────────────────────────────────
PORT=3001

# ── Database adapter: "postgres" | "supabase" ─────────────
DB_ADAPTER=postgres

# Postgres (used when DB_ADAPTER=postgres)
DATABASE_URL=postgres://dostt:dostt_secret@localhost:5432/dostt_rewards

# Supabase (used when DB_ADAPTER=supabase)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=30d

# ── OTP provider: "twilio" | "2factor" ────────────────────
OTP_PROVIDER=twilio

# Twilio (used when OTP_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM=+1xxxxxxxxxx

# 2Factor.in (used when OTP_PROVIDER=2factor)
TWOFACTOR_API_KEY=your_2factor_api_key
TWOFACTOR_TEMPLATE_NAME=your_template_name

# ── Go-live date ──────────────────────────────────────────
# Only total_spent from rows where last_refreshed_at_ist >= GO_LIVE_DATE counts.
# Set this to the datetime the rewards feature went live (ISO 8601, IST).
# Leave blank during development to count all spend.
GO_LIVE_DATE=
CYCLE_DAYS=30

# ── Redash ────────────────────────────────────────────────
REDASH_BASE_URL=https://app.redash.io/yourslug
REDASH_API_KEY=your_query_or_user_api_key

# Query ID for verifying a phone is a registered Dostt user
# Expected query: SELECT user_id, mobile_no FROM users WHERE mobile_no = '{{ phone }}'
# Leave blank to skip phone verification and allow any number to request OTP
REDASH_VERIFY_PHONE_QUERY_ID=

# Query ID for fetching per-user points (replaces Google Sheets sync)
# Expected columns: user_id, mobile_no, wallet_balance, spent_on_audio,
#   spent_on_video, total_spent, last_refreshed_at_ist, ltv
# Cached in user_points table with 2-hour TTL.
REDASH_USER_POINTS_QUERY_ID=17564

# ── Dostt Wallet API ──────────────────────────────────────
# Used to credit free coins after a successful tier claim.
# Sends a CSV (user_id,coins) as multipart form-data.
DOSTT_WALLET_API_URL=https://api.dostt.in/payments/free-coins/upload/
DOSTT_WALLET_AUTH_KEY=your_x-n8n-auth-key

# ── Admin reporting API ───────────────────────────────────
# Set to a long random string. Pass as x-admin-key header to /admin/* endpoints.
ADMIN_API_KEY=change_me_to_a_long_random_string

# ── Google Sheets (disabled — remove these from your environment) ──────────
# GOOGLE_SHEETS_ID=your_spreadsheet_id
# GOOGLE_SHEET_NAME=Sheet1
# GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./google-service-account.json
